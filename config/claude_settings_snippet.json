{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "__AGENT_MEMORY_SYNC_PYTHON__ __AGENT_MEMORY_SYNC_ROOT__/hooks/session_start.py",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__AGENT_MEMORY_SYNC_PYTHON__ __AGENT_MEMORY_SYNC_ROOT__/hooks/stop.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "__AGENT_MEMORY_SYNC_PYTHON__ __AGENT_MEMORY_SYNC_ROOT__/hooks/post_tool_use.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
